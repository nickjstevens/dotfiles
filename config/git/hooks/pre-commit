#!/usr/bin/env bash
set -euo pipefail

if [ "${SKIP_MARKDOWNLINT_PRECOMMIT:-0}" = "1" ]; then
    exit 0
fi

# Allow generated/documentation-heavy repos to opt out locally with:
#   git config hooks.markdownlint false
# This keeps the global hook useful without making unsuitable repos painful in
# GUI clients such as VS Code, where large hook output can look like a hang.
if [ "$(git config --type=bool --get hooks.markdownlint || printf true)" = "false" ]; then
    exit 0
fi

mapfile -d '' markdown_files < <(git diff --cached --name-only --diff-filter=ACMR -z -- '*.md' '*.markdown')

if [ "${#markdown_files[@]}" -eq 0 ]; then
    exit 0
fi

runner=()
if command -v markdownlint-cli2 >/dev/null 2>&1; then
    runner=(markdownlint-cli2)
elif [ -x "node_modules/.bin/markdownlint-cli2" ]; then
    runner=("$PWD/node_modules/.bin/markdownlint-cli2")
elif command -v npx >/dev/null 2>&1 && [ -f package.json ]; then
    runner=(npx --no-install markdownlint-cli2)
else
    echo "markdownlint-cli2 is required to lint staged Markdown files." >&2
    echo "Install it globally with: npm install --global markdownlint-cli2" >&2
    echo "Or add it to this repo and commit again." >&2
    exit 1
fi

lint_targets=()
for file in "${markdown_files[@]}"; do
    lint_targets+=(":$file")
done

echo "Linting staged Markdown files with markdownlint-cli2..."
"${runner[@]}" --no-globs "${lint_targets[@]}"
